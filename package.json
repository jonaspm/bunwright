{
  "name": "bunwright",
  "version": "0.3.0",
  "description": "The lightweight browser automation library for Bun",
  "homepage": "https://github.com/jonaspm/bunwright#readme",
  "bugs": {
    "url": "https://github.com/jonaspm/bunwright/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonaspm/bunwright.git"
  },
  "bin": {
    "bunwright": "dist/bunwright.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/types.d.ts",
  "scripts": {
    "build": "bun run build:dist && bun run build:types",
    "build:dist": "bun build.ts",
    "build:types": "bun --bun tsc --declaration --emitDeclarationOnly --outDir dist --ignoreConfig --types bun src/dsl/index.ts",
    "docs": "bun run build && bun run scripts/generate-api-docs.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint-staged": "lint-staged",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "1.3.14",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "simple-git-hooks": "^2.11.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md}": "oxfmt"
  },
  "engines": {
    "bun": ">=1.3.12"
  }
}

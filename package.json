{
  "name": "bunwright-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint-staged": "lint-staged",
    "prepare": "node -e \"try{const m=require('simple-git-hooks');if(!m.skipInstall())m.setHooksFromConfig(process.cwd(),process.argv)}catch(e){if(e.code!=='MODULE_NOT_FOUND')throw e}\""
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "simple-git-hooks": "^2.11.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md}": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.14"
}
